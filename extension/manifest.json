{
  "manifest_version": 3,
  "name": "Karakeep Sidebar",
  "description": "Karakeep bookmarking — exposed as a Firefox sidebar panel.",
  "version": "1.2.12.7",
  "icons": {
    "16": "public/logo-16.png",
    "48": "public/logo-48.png",
    "128": "public/logo-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Karakeep",
    "theme_icons": [
      {
        "light": "logo-16-darkmode.png",
        "dark": "logo-16.png",
        "size": 16
      },
      {
        "light": "logo-48-darkmode.png",
        "dark": "logo-48.png",
        "size": 48
      },
      {
        "light": "logo-128-darkmode.png",
        "dark": "logo-128.png",
        "size": 128
      }
    ]
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "scripts": [
      "src/background/background.ts"
    ]
  },
  "sidebar_action": {
    "default_panel": "index.html#/sidebar",
    "default_title": "Karakeep",
    "default_icon": {
      "16": "public/logo-16.png",
      "48": "public/logo-48.png",
      "128": "public/logo-128.png"
    },
    "open_at_install": false
  },
  "options_ui": {
    "page": "index.html#options",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "karakeep-sidebar@sushistack"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https:; child-src https:"
  },
  "permissions": [
    "storage",
    "tabs",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://karakeep.invalid/*"
      ],
      "js": [
        "src/content-scripts/singlefile-content-script.ts"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "add-link": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "Send the current page URL to Karakeep."
    },
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K"
      },
      "description": "Toggle the Karakeep sidebar."
    }
  }
}
